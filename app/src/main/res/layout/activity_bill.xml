<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1A237E"
            app:titleTextColor="@android:color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <!-- ══ ACTIVE ITEM POLICY CARD ══ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardActivePolicy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="#E65100"
                            android:layout_marginEnd="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active Rentals Detected"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#E65100" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Some items are still active. How should they be billed?"
                        android:textSize="13sp"
                        android:textColor="#555"
                        android:layout_marginBottom="12dp" />

                    <!-- Toggle buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPolicyNow"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="Calculate up to now"
                            android:textSize="12sp"
                            app:cornerRadius="8dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPolicyPending"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="Mark as pending"
                            android:textSize="12sp"
                            app:cornerRadius="8dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPolicyNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:background="#F5F6FA"
                        android:padding="10dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ RENTALS LIST ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <View android:layout_width="4dp" android:layout_height="20dp"
                    android:background="#1A237E" android:layout_marginEnd="8dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rentals"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A237E" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRentals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="14dp" />

            <!-- ══ DAMAGE LIST ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <View android:layout_width="4dp" android:layout_height="20dp"
                    android:background="#B71C1C" android:layout_marginEnd="8dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Damage Charges"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#B71C1C" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerDamages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="14dp" />

            <!-- ══ MISSING LIST ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <View android:layout_width="4dp" android:layout_height="20dp"
                    android:background="#E65100" android:layout_marginEnd="8dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Missing Items"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E65100" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerMissing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="14dp" />

            <!-- ══ TOTALS CARD ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="12dp" android:layout_marginBottom="0dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Rentals gross"
                            android:textSize="13sp" android:textColor="#555" />
                        <TextView android:id="@+id/tvRentalGross"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0.00" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="#212121" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:paddingStart="12dp"
                        android:paddingEnd="12dp" android:paddingBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="(-) Advance paid"
                            android:textSize="13sp" android:textColor="#555" />
                        <TextView android:id="@+id/tvAdvance"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="-0.00" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="#2E7D32" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:paddingStart="12dp"
                        android:paddingEnd="12dp" android:paddingBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="(-) Security deposit"
                            android:textSize="13sp" android:textColor="#555" />
                        <TextView android:id="@+id/tvSecurity"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="-0.00" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="#2E7D32" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:paddingStart="12dp"
                        android:paddingEnd="12dp" android:paddingBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="(+) Damage charges"
                            android:textSize="13sp" android:textColor="#555" />
                        <TextView android:id="@+id/tvDamage"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="+0.00" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="#B71C1C" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:paddingStart="12dp"
                        android:paddingEnd="12dp" android:paddingBottom="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="(+) Unpaid missing"
                            android:textSize="13sp" android:textColor="#555" />
                        <TextView android:id="@+id/tvMissing"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="+0.00" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="#B71C1C" />
                    </LinearLayout>

                    <!-- Pending warning -->
                    <TextView android:id="@+id/tvPendingWarning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:textColor="#E65100"
                        android:background="#FFF8E1"
                        android:padding="10dp"
                        android:visibility="gone" />

                    <!-- Grand total -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="#1A237E">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="TOTAL DUE"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#9FA8DA" />
                        <TextView android:id="@+id/tvGrandTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.00"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/white" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ ACTION BUTTONS ══ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrintPdf"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Print / Save as PDF"
                android:textSize="15sp"
                app:backgroundTint="#1A237E"
                app:cornerRadius="10dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShare"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="Share via App"
                    android:textSize="13sp"
                    android:textColor="#1A237E"
                    app:strokeColor="#1A237E"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:cornerRadius="10dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveHistory"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="Save to History"
                    android:textSize="13sp"
                    android:textColor="#2E7D32"
                    app:strokeColor="#2E7D32"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:cornerRadius="10dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
