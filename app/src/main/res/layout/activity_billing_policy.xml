<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar" android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary" app:titleTextColor="@android:color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="18dp">

            <!-- Info card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardBackgroundColor="#E3F2FD" app:cardCornerRadius="12dp" app:cardElevation="0dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="These settings control how leftover hours are billed when a rental spans an uneven duration, e.g. 5 days and 7 extra hours."
                    android:textSize="13sp" android:textColor="#1565C0" />
            </androidx.cardview.widget.CardView>

            <!-- ── DAILY POLICY ── -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DAILY RENTALS — leftover hours"
                android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp" />

            <RadioGroup android:id="@+id/rgDaily"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">

                <!-- Exact hours option -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="10dp" app:cardElevation="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp">
                        <RadioButton android:id="@+id/rbDailyExact"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Charge exact leftover hours"
                            android:textSize="14sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Leftover hours billed at dailyRate ÷ 24\nExample: 5 days 7 hrs at ₱50/day → ₱250 + 7×₱2.08 = ₱264.58"
                            android:textSize="12sp" android:textColor="@color/text_secondary"
                            android:layout_marginStart="32dp" android:layout_marginTop="2dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Round up option -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="10dp" app:cardElevation="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp">
                        <RadioButton android:id="@+id/rbDailyRound"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Round up to next full day"
                            android:textSize="14sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Any leftover hours = one full extra day charge\nExample: 5 days 7 hrs at ₱50/day → 6 days = ₱300"
                            android:textSize="12sp" android:textColor="@color/text_secondary"
                            android:layout_marginStart="32dp" android:layout_marginTop="2dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Grace period option -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="10dp" app:cardElevation="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp">
                        <RadioButton android:id="@+id/rbDailyGrace"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Grace period then full day"
                            android:textSize="14sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="If leftover &lt; grace hours → free. Otherwise → full extra day."
                            android:textSize="12sp" android:textColor="@color/text_secondary"
                            android:layout_marginStart="32dp" android:layout_marginTop="2dp" />

                        <!-- Grace hours input (shown/hidden by code) -->
                        <LinearLayout android:id="@+id/layoutGrace"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginStart="32dp" android:layout_marginTop="8dp"
                            android:visibility="gone">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Grace hours: " android:textSize="13sp"
                                android:textColor="@color/text_primary" />
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="80dp" android:layout_height="wrap_content"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etGraceHours"
                                    android:layout_width="match_parent" android:layout_height="wrap_content"
                                    android:inputType="number" android:text="6"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text=" hrs free" android:textSize="13sp"
                                android:textColor="@color/text_secondary" android:layout_marginStart="6dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </RadioGroup>

            <!-- ── MONTHLY POLICY ── -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="MONTHLY RENTALS — leftover hours (after days)"
                android:textSize="12sp" android:textStyle="bold" android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp" android:layout_marginTop="10dp" />

            <RadioGroup android:id="@+id/rgMonthly"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="10dp" app:cardElevation="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp">
                        <RadioButton android:id="@+id/rbMonthlyExact"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Charge exact leftover hours"
                            android:textSize="14sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Months → days → hours at hourly rate\nExample: 1 mo 3 days 5 hrs → ₱500 + ₱50 + ₱3.47"
                            android:textSize="12sp" android:textColor="@color/text_secondary"
                            android:layout_marginStart="32dp" android:layout_marginTop="2dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="10dp" app:cardElevation="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp">
                        <RadioButton android:id="@+id/rbMonthlyRound"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Round up leftover hours to full day"
                            android:textSize="14sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Any leftover hours after days = one extra full day\nExample: 1 mo 3 days 5 hrs → 1 mo 4 days"
                            android:textSize="12sp" android:textColor="@color/text_secondary"
                            android:layout_marginStart="32dp" android:layout_marginTop="2dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </RadioGroup>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:text="Save Policy" android:textSize="16sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
