<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.renteasy.activities">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="RentEasy"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RentEasy">

        <!-- LAUNCHER activity -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".MainActivity"           android:exported="false" />
        <activity android:name=".CustomerListActivity"   android:exported="false" />
        <activity android:name=".CustomerDetailActivity" android:exported="false" />
        <activity android:name=".AddCustomerActivity"    android:exported="false" />
        <activity android:name=".AddRentalActivity"      android:exported="false" />
        <activity android:name=".AddMissingItemActivity" android:exported="false" />
        <activity android:name=".AddDamageActivity" />
        <activity android:name=".BillingPolicyActivity" />
        <activity android:name=".BillActivity" />
        <activity android:name=".BillHistoryActivity" />

    </application>

</manifest>